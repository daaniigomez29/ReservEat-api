    {
      "name": "6 - Test scenarios (requisitos)",
      "item": [
        {
          "name": "A) Best-fit: party 4 -> mesa de capacidad 4 (M2)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('reservationId', j.id);",
                  "pm.test('CONFIRMED', () => pm.expect(j.status).to.eql('CONFIRMED'));",
                  "// La mesa asignada se verifica en la siguiente petición (owner). Aquí solo guardamos el id.",
                  "// party 4 no cabe en M1 (cap 2-3), cabe justo en M2 (4) y tambien en M3 (6) -> best-fit = M2."
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restaurantId\": {{restaurantId}},\n  \"startDate\": \"{{slotBestfit}}\",\n  \"partySize\": 4\n}"
            },
            "url": { "raw": "{{baseUrl}}/reservations", "host": ["{{baseUrl}}"], "path": ["reservations"] }
          }
        },
        {
          "name": "A.2) Verificar best-fit = M2 (owner)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const arr = pm.response.json();",
                  "const rid = Number(pm.collectionVariables.get('reservationId'));",
                  "const r = arr.find(x => x.id === rid);",
                  "pm.test('Reserva encontrada', () => pm.expect(r).to.be.an('object'));",
                  "pm.test('Asignó la mesa de capacidad 4 (label M2)', () => pm.expect(r.tableLabel).to.eql('M2'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ownerToken}}" }],
            "url": { "raw": "{{baseUrl}}/reservations/restaurant/{{restaurantId}}", "host": ["{{baseUrl}}"], "path": ["reservations", "restaurant", "{{restaurantId}}"] }
          }
        },
        {
          "name": "B) Conflicto de aforo: party 50 -> 409",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('409 Conflict', () => pm.response.to.have.status(409));",
                  "pm.test('Mensaje sin mesa disponible', () => pm.expect(pm.response.text()).to.include('No table available'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
