          "name": "Create Reservation (party 3)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Nace CONFIRMED', () => pm.expect(j.status).to.eql('CONFIRMED'));",
                  "pm.test('El cliente NO ve mesa', () => pm.expect(j.tableId === undefined || j.tableId === null).to.be.true);",
                  "pm.collectionVariables.set('reservationId', j.id);"
                ]
